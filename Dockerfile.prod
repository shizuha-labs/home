# =============================================================================
# Production Dockerfile for Shizuha Home
# =============================================================================
# Multi-stage build: Build static files from frontend/ subdir, then serve with nginx
# NO HMR, NO Vite dev server - optimized static files only
#
# Build args (set via docker-compose):
#   VITE_BASE_PATH - e.g., /
#   VITE_API_BASE - e.g., /api
#   FRONTEND_PATH - e.g., shizuha-home (relative to monorepo root)
#
# Context: Monorepo root (to access /packages)
# =============================================================================

# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Build arg for frontend path (relative to monorepo root)
ARG FRONTEND_PATH=home

# Copy shared packages first (for vite.shared.js)
COPY packages/shizuha-ui /packages/shizuha-ui
COPY packages/shizuha-chat /packages/shizuha-chat

# Install shared package dependencies (needed for build)
RUN cd /packages/shizuha-ui && npm install --omit=dev
RUN cd /packages/shizuha-chat && npm install --omit=dev

# HIVE-694 (2026-07-12): npm>=7 auto-installs peerDependencies, so the installs
# above plant a NESTED react/react-dom under each package. The vite aliases
# point at package SOURCE, so under vite 6 imports of 'react' from /packages/...
# resolved to those nested copies — TWO reacts in the bundle → hooks dispatcher
# null → "useState of null" crash on shizuha.com. Remove them so the app's own
# react is the only candidate (vite resolve.dedupe is the belt; this is braces).
RUN rm -rf /packages/shizuha-ui/node_modules/react /packages/shizuha-ui/node_modules/react-dom \
           /packages/shizuha-chat/node_modules/react /packages/shizuha-chat/node_modules/react-dom

# Install dependencies first (better caching)
# Note: shizuha-home has frontend/ subdirectory
# Use only package.json (not package-lock.json) to avoid lock file path resolution issues
COPY ${FRONTEND_PATH}/frontend/package.json ./
RUN npm install

# Copy source from frontend subdirectory
COPY ${FRONTEND_PATH}/frontend/ .

# Build args for Vite
ARG VITE_BASE_PATH=/
ARG VITE_API_BASE=/api
ENV VITE_BASE_PATH=$VITE_BASE_PATH
ENV VITE_API_BASE=$VITE_API_BASE
ENV NODE_ENV=production

# Build static files
RUN npm run build

# Stage 2: Serve with nginx
FROM nginx:alpine

# Build arg needed again in stage 2
ARG FRONTEND_PATH=home

# Copy custom nginx config (nginx.prod.conf is at shizuha-home root, not frontend/)
COPY ${FRONTEND_PATH}/nginx.prod.conf /etc/nginx/conf.d/default.conf
RUN nginx -t

# Copy built static files
COPY --from=builder /app/dist /usr/share/nginx/html

# Expose port 80
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
